# ─── Frontend ──────────────────────────────────────────────────────────────
# Vite dev server URL
VITE_API_URL=https://paste-api.collacou.workers.dev

# R2 Signer Worker URL (the Cloudflare Worker in workers/r2-signer)
# This is the ONLY R2-related env var that belongs in the frontend.
# It is a public URL — not a credential.
VITE_R2_SIGNER_URL=https://your-r2-signer.workers.dev

# ─── Server-Side Only (Wrangler Secrets, never in frontend) ────────────────
# Set these via: wrangler secret put <NAME>
# NEVER prefix these with VITE_ — they would be exposed to browsers.
#
# paste-api worker:
#   TOKEN_SECRET=<random 32+ char string>
#   DEV_PASSCODE=<your admin passcode>
#   DEV_PASSCODE_2=<optional second admin passcode>
#   R2_ACCOUNT_ID=<cloudflare account id>
#   R2_BUCKET_NAME=<r2 bucket name>
#
# r2-signer worker:
#   R2_ACCOUNT_ID=<cloudflare account id>
#   R2_BUCKET_NAME=<r2 bucket name>
#   R2_ACCESS_KEY_ID=<r2 s3-api access key>
#   R2_SECRET_ACCESS_KEY=<r2 s3-api secret key>
#   TOKEN_SECRET=<must match paste-api TOKEN_SECRET>
#   R2_REGION=auto   (optional)
